{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "account.ts",
        "accountOnboarding.ts",
        "accountOnboardingStack.ts",
        "certificate.ts",
        "commitRulestack.ts",
        "config/index.ts",
        "config/vars.ts",
        "customUrlCategory.ts",
        "fqdnList.ts",
        "getAccount.ts",
        "getAccounts.ts",
        "getAppIdVersion.ts",
        "getAppIdVersions.ts",
        "getCertificate.ts",
        "getCountry.ts",
        "getCustomUrlCategory.ts",
        "getFqdnList.ts",
        "getIntelligentFeed.ts",
        "getNgfw.ts",
        "getNgfwLogProfile.ts",
        "getNgfws.ts",
        "getPredefinedUrlCategories.ts",
        "getPredefinedUrlCategoryOverride.ts",
        "getPrefixList.ts",
        "getRulestack.ts",
        "getSecurityRule.ts",
        "getValidateRulestack.ts",
        "index.ts",
        "intelligentFeed.ts",
        "ngfw.ts",
        "ngfwLogProfile.ts",
        "predefinedUrlCategoryOverride.ts",
        "prefixList.ts",
        "provider.ts",
        "rulestack.ts",
        "securityRule.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts"
    ]
}
